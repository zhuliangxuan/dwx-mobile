{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "凡尘问道",
  "version": "0.1.0",
  "identifier": "com.dwx.app",
  "build": {
    "frontendDist": "../../dwx-server/static",
    "devUrl": "http://localhost:4000",
    "beforeBuildCommand": "cd /mnt/data/dwx-server/frontend && pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "凡尘问道",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
